{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10,
  "ignorePaths": ["**/test/resources/**"],
  "constraints": { "pnpm": "10.28.2", "node": "24.13.0" },
  "lockFileMaintenance": {
    "enabled": true,
    "groupName": "all non-major dependencies",
    "groupSlug": "non-major"
  },
  "packageRules": [
    {
      "description": "Default group for major updates (specific groups below override)",
      "matchUpdateTypes": ["major"],
      "groupName": "all non-major dependencies",
      "groupSlug": "non-major"
    },
    {
      "description": "Default group for minor/patch updates (specific groups below override)",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "non-major",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group epistola-contract packages (server SDK + editor model) together",
      "matchPackageNames": ["app.epistola.contract*", "@epistola.app/**"],
      "groupName": "epistola-contract",
      "groupSlug": "epistola-contract",
      "automerge": false
    },
    {
      "description": "Group toolchain updates (Kotlin, Gradle, Kover, Java, Node, pnpm) into a separate PR",
      "matchPackageNames": [
        "org.jetbrains.kotlin*",
        "org.jetbrains.kotlinx.kover*",
        "org.jetbrains.kotlinx:kover-gradle-plugin",
        "gradle",
        "java",
        "node",
        "pnpm"
      ],
      "groupName": "toolchain",
      "groupSlug": "toolchain",
      "automerge": false
    },
    {
      "description": "Group all GitHub Actions updates (minor, major, digests) into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "groupSlug": "github-actions",
      "automerge": false
    }
  ],
  "gradle": {
    "fileMatch": ["(^|/)build\\.gradle\\.kts$", "(^|/)settings\\.gradle\\.kts$"]
  }
}
