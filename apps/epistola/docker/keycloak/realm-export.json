{
  "realm": "epistola",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "organizationsEnabled": true,
  "groups": [
    {
      "name": "ep_demo-tenant_reader"
    },
    {
      "name": "ep_demo-tenant_editor"
    },
    {
      "name": "ep_demo-tenant_generator"
    },
    {
      "name": "ep_demo-tenant_manager"
    },
    {
      "name": "ep_tenant-manager"
    },
    {
      "name": "ep_reader"
    },
    {
      "name": "ep_editor"
    },
    {
      "name": "ep_generator"
    },
    {
      "name": "ep_manager"
    }
  ],
  "clients": [
    {
      "clientId": "epistola-suite",
      "name": "Epistola Suite",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "epistola-dev-secret",
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "http://localhost:4000/*"
      ],
      "webOrigins": [
        "http://localhost:4000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4000/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "openid"
      ],
      "protocolMappers": [
        {
          "name": "group-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@test",
      "email": "admin@test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": [
        "ep_demo-tenant_reader",
        "ep_demo-tenant_editor",
        "ep_demo-tenant_generator",
        "ep_demo-tenant_manager",
        "ep_tenant-manager",
        "ep_reader",
        "ep_editor",
        "ep_generator",
        "ep_manager"
      ]
    },
    {
      "username": "user@test",
      "email": "user@test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Regular",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": [
        "ep_demo-tenant_reader",
        "ep_demo-tenant_editor",
        "ep_demo-tenant_generator"
      ]
    },
    {
      "username": "service-account-epistola-suite",
      "enabled": true,
      "serviceAccountClientId": "epistola-suite",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users"
        ]
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "default-roles-epistola",
        "composite": true,
        "composites": {
          "client": {
            "account": ["view-profile", "manage-account"]
          }
        }
      }
    ]
  }
}
