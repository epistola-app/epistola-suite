{
  "realm": "epistola",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "organizationsEnabled": true,
  "groups": [
    {
      "name": "epistola",
      "subGroups": [
        {
          "name": "tenants",
          "subGroups": [
            {
              "name": "demo",
              "subGroups": [
                { "name": "reader" },
                { "name": "editor" },
                { "name": "generator" },
                { "name": "manager" }
              ]
            }
          ]
        },
        {
          "name": "global",
          "subGroups": [
            { "name": "reader" },
            { "name": "editor" },
            { "name": "generator" },
            { "name": "manager" }
          ]
        },
        {
          "name": "platform",
          "subGroups": [{ "name": "tenant-manager" }]
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "epistola-suite",
      "name": "Epistola Suite",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "epistola-dev-secret",
      "serviceAccountsEnabled": true,
      "redirectUris": ["http://localhost:4000/*"],
      "webOrigins": ["http://localhost:4000"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4000/*"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email", "openid"],
      "protocolMappers": [
        {
          "name": "group-membership-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@demo",
      "email": "admin@demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": [
        "/epistola/tenants/demo/reader",
        "/epistola/tenants/demo/editor",
        "/epistola/tenants/demo/generator",
        "/epistola/tenants/demo/manager",
        "/epistola/platform/tenant-manager",
        "/epistola/global/reader",
        "/epistola/global/editor",
        "/epistola/global/generator",
        "/epistola/global/manager"
      ]
    },
    {
      "username": "reader@demo",
      "email": "reader@demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Reader",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "reader",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": ["/epistola/tenants/demo/reader"]
    },
    {
      "username": "editor@demo",
      "email": "editor@demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Editor",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "editor",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": ["/epistola/tenants/demo/reader", "/epistola/tenants/demo/editor"]
    },
    {
      "username": "generator@demo",
      "email": "generator@demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Generator",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "generator",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": ["/epistola/tenants/demo/reader", "/epistola/tenants/demo/generator"]
    },
    {
      "username": "manager@demo",
      "email": "manager@demo",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Manager",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "manager",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "groups": [
        "/epistola/tenants/demo/reader",
        "/epistola/tenants/demo/editor",
        "/epistola/tenants/demo/generator",
        "/epistola/tenants/demo/manager"
      ]
    },
    {
      "username": "service-account-epistola-suite",
      "enabled": true,
      "serviceAccountClientId": "epistola-suite",
      "clientRoles": {
        "realm-management": ["manage-users", "view-users", "query-users"]
      }
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "default-roles-epistola",
        "composite": true,
        "composites": {
          "client": {
            "account": ["view-profile", "manage-account"]
          }
        }
      }
    ]
  }
}
