{
  "realm": "epistola",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "organizationsEnabled": true,
  "clients": [
    {
      "clientId": "epistola-suite",
      "name": "Epistola Suite",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "epistola-dev-secret",
      "redirectUris": [
        "http://localhost:4000/*"
      ],
      "webOrigins": [
        "http://localhost:4000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:4000/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email",
        "openid"
      ],
      "protocolMappers": [
        {
          "name": "epistola-tenants-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-organization-membership-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "epistola_tenants",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "epistola-client-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "userinfo.token.claim": "true",
            "multivalued": "true",
            "usermodel.clientRoleMapping.clientId": "epistola-suite"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@test",
      "email": "admin@test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"],
      "clientRoles": {
        "epistola-suite": ["tenant-manager"]
      }
    },
    {
      "username": "user@test",
      "email": "user@test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Regular",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-epistola"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "default-roles-epistola",
        "composite": true,
        "composites": {
          "client": {
            "account": ["view-profile", "manage-account"]
          }
        }
      }
    ],
    "client": {
      "epistola-suite": [
        {
          "name": "tenant-manager",
          "description": "Can create and manage tenants across the platform"
        }
      ]
    }
  }
}
