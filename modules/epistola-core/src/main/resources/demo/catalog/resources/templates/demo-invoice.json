    "templateModel": {
      "modelVersion": 1,
      "root": "n-root",
      "themeRef": {
        "type": "override",
        "themeId": "corporate"
      },
      "pageSettingsOverride": {
        "format": "A4",
        "orientation": "portrait",
        "margins": {
          "top": 40,
          "right": 40,
          "bottom": 40,
          "left": 40
        }
      },
      "documentStylesOverride": {
        "fontFamily": "Helvetica",
        "fontSize": "10pt",
        "color": "#333333"
      },
      "nodes": {
        "n-root": {
          "id": "n-root",
          "type": "root",
          "slots": [
            "s-root-children"
          ]
        },
        "n-header": {
