                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "expression",
                      "attrs": {
                        "expression": "vendor.address",
                        "isNew": false
                      }
                    },
                    {
                      "type": "hard_break"
                    },
                    {
                      "type": "expression",
                      "attrs": {
                        "expression": "vendor.zipCode",
                        "isNew": false
                      }
                    },
                    {
                      "type": "text",
