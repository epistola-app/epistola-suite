                    },
                    {
                      "type": "hard_break"
                    },
                    {
                      "type": "text",
                      "text": "Date: "
                    },
                    {
                      "type": "expression",
                      "attrs": {
                        "expression": "$formatDate(invoiceDate, 'dd-MM-yyyy')",
                        "isNew": false
                      }
                    },
                    {
                      "type": "hard_break"
                    },
                    {
                      "type": "text",
                      "text": "Due Date: "
                    },
                    {
                      "type": "expression",
