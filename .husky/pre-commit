# Block secrets from entering a commit. Scans ONLY staged changes (fast — ~0.4s),
# using the gitleaks version pinned in .mise.toml. CI re-scans full history as
# the hard gate (a hook is bypassable with --no-verify). Config: .gitleaks.toml.
if command -v mise >/dev/null 2>&1; then
  mise exec -- gitleaks git --staged --no-banner --redact
else
  echo "mise not found — skipping local secret scan (run 'mise install'); CI will still scan." >&2
fi
