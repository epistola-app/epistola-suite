{
  "name": "epistola-suite",
  "private": true,
  "description": "Epistola Suite - Document generation platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "lint:css": "stylelint 'modules/**/*.css' 'apps/**/*.css'",
    "setup:github-mcp": "pnpm --filter @epistola/gh-mcp run setup"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@scalar/api-reference": "^1.62.2",
    "htmx.org": "2.0.10"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^7.0.0",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^7.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
