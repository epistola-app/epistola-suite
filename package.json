{
  "name": "epistola-suite",
  "private": true,
  "description": "Epistola Suite - Document generation platform",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint",
    "setup:github-mcp": "pnpm --filter @epistola/gh-mcp run setup"
  },
  "devDependencies": {
    "oxfmt": "^0.47.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.22.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
